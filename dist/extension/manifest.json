{
    "name": "Form Filler",
    "version": "1.0",
    "description": "Form filler using LLMs to generate relevant fake data",
    "manifest_version": 3,
    "action": {
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "contextMenus"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js", "llm/system.js"],
            "all_frames": true
        }
    ]
}